# programs/flatten_test.cyr — RUN test for adaptive Bézier flattening.
#
# Asserts structural invariants (endpoints, subdivision, convex-hull bbox, a
# known t=0.5 split point) rather than exact tessellation counts, so it stays
# valid if the flatness heuristic is tuned. Exit code = failed checks.

include "src/lib.cyr"

var g_fails = 0;

fn check(got, want): i64 {
    if (got == want) { return 0; }
    g_fails = g_fails + 1;
    return 1;
}

# Is (x, y) present among the polyline's points?
fn pl_has(pl, x, y): i64 {
    var pts = sd_polyline_points(pl);
    var n = sd_polyline_count(pl);
    var i = 0;
    while (i < n) {
        var p = load64(pts + i * 8);
        if (sd_point_x(p) == x) {
            if (sd_point_y(p) == y) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

# Are ALL polyline points inside [x0,x1] x [y0,y1]?
fn pl_in_bbox(pl, x0, y0, x1, y1): i64 {
    var pts = sd_polyline_points(pl);
    var n = sd_polyline_count(pl);
    var i = 0;
    while (i < n) {
        var p = load64(pts + i * 8);
        var px = sd_point_x(p);
        var py = sd_point_y(p);
        if (px < x0) { return 0; }
        if (px > x1) { return 0; }
        if (py < y0) { return 0; }
        if (py > y1) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn main(): i64 {
    alloc_init();
    var tol = SD_ONE >> 2;   # 0.25 px flatness

    # --- straight line: 2 anchors, no subdivision ---
    var sp = sd_path_new();
    sd_path_moveto(sp, 0, 0);
    sd_path_lineto(sp, 4 * SD_ONE, 0);
    var spl = sd_path_flatten(sp, tol);
    check(sd_polyline_count(spl), 2);

    # --- collinear "quad" (control on the chord) collapses to 2 points ---
    var cq = sd_path_new();
    sd_path_moveto(cq, 0, 0);
    sd_path_quadto(cq, 2 * SD_ONE, 0, 4 * SD_ONE, 0);
    var cql = sd_path_flatten(cq, tol);
    check(sd_polyline_count(cql), 2);

    # --- symmetric real quad: p0(0,0) c(2,2) p2(4,0) ---
    var qp = sd_path_new();
    sd_path_moveto(qp, 0, 0);
    sd_path_quadto(qp, 2 * SD_ONE, 2 * SD_ONE, 4 * SD_ONE, 0);
    var qpl = sd_path_flatten(qp, tol);
    var qc = sd_polyline_count(qpl);
    if (qc < 3) { g_fails = g_fails + 1; }              # subdivided
    var qpts = sd_polyline_points(qpl);
    check(sd_point_x(load64(qpts + 0)), 0);             # first == p0
    check(sd_point_y(load64(qpts + 0)), 0);
    check(sd_point_x(load64(qpts + (qc - 1) * 8)), 4 * SD_ONE);  # last == p2
    check(sd_point_y(load64(qpts + (qc - 1) * 8)), 0);
    check(pl_has(qpl, 2 * SD_ONE, 1 * SD_ONE), 1);      # exact t=0.5 point (2,1)
    check(pl_in_bbox(qpl, 0, 0, 4 * SD_ONE, 2 * SD_ONE), 1);     # convex hull

    # --- cubic: p0(0,0) c1(0,4) c2(4,4) p3(4,0) ---
    var kp = sd_path_new();
    sd_path_moveto(kp, 0, 0);
    sd_path_cubicto(kp, 0, 4 * SD_ONE, 4 * SD_ONE, 4 * SD_ONE, 4 * SD_ONE, 0);
    var kpl = sd_path_flatten(kp, tol);
    var kc = sd_polyline_count(kpl);
    if (kc < 3) { g_fails = g_fails + 1; }
    var kpts = sd_polyline_points(kpl);
    check(sd_point_x(load64(kpts + 0)), 0);             # first == p0
    check(sd_point_y(load64(kpts + 0)), 0);
    check(sd_point_x(load64(kpts + (kc - 1) * 8)), 4 * SD_ONE);  # last == p3
    check(sd_point_y(load64(kpts + (kc - 1) * 8)), 0);
    check(pl_in_bbox(kpl, 0, 0, 4 * SD_ONE, 4 * SD_ONE), 1);     # convex hull

    if (g_fails == 0) {
        var ok = "flatten_test: PASS (de Casteljau)\n";
        syscall(1, 1, ok, strlen(ok));
    } else {
        var bad = "flatten_test: FAIL\n";
        syscall(1, 2, bad, strlen(bad));
    }
    return g_fails;
}

var exit_code = main();
syscall(60, exit_code);
